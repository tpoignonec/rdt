// Dev Container configuration for ROS 2 workspace.
// Generated by rdt init — customise as needed.
{
    "name": "ROS 2 — PROJECT_NAME",
    "build": {
        "dockerfile": "Dockerfile",
        "args": { "ROS_DISTRO": "ROS_DISTRO" }
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/ws,type=bind",
    "workspaceFolder": "/ws",
    "remoteUser": "dev",
    "runArgs": [
        "--network=host",
        "--ipc=host",
        "--privileged",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix:rw"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "xaver.clang-format",
                "ms-python.python",
                "charliermarsh.ruff",
                "redhat.vscode-xml",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "cmake.configureOnOpen": false,
                "clangd.arguments": [
                    "--compile-commands-dir=${workspaceFolder}/build",
                    "--header-insertion=never"
                ],
                "files.associations": {
                    "*.xacro": "xml",
                    "*.urdf": "xml",
                    "*.launch.py": "python",
                    "*.repos": "yaml"
                }
            }
        }
    },
    "postStartCommand": "echo 'source /opt/ros/ROS_DISTRO/setup.bash' >> ~/.bashrc",
    "postCreateCommand": "rdt deps --skip-apt"
}
