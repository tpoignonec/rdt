{
    // ROS 2 / colcon workspace settings.
    // Generated by rdt init — customise as needed.

    "search.exclude": {
        "**/build": true,
        "**/install": true,
        "**/log": true
    },
    "files.watcherExclude": {
        "**/build/**": true,
        "**/install/**": true,
        "**/log/**": true
    },

    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--header-insertion=never"
    ],

    "python.analysis.extraPaths": [
        "${workspaceFolder}/install/lib/python3/dist-packages"
    ],

    "files.associations": {
        "*.xacro": "xml",
        "*.urdf": "xml",
        "*.sdf": "xml",
        "*.launch.py": "python",
        "*.repos": "yaml"
    },

    "cmake.configureOnOpen": false,
    "cmake.ignoreCMakeListsMissing": true
}
