// Dev Container configuration for ROS 2 workspace.
// Generated by rdt init — customise as needed.
//
// Docs: https://containers.dev/implementors/json_reference/
{
    "name": "ROS 2 Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "ROS_DISTRO": "jazzy"
        }
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/ws,type=bind",
    "workspaceFolder": "/ws",

    // Run as non-root user (created in Dockerfile)
    "remoteUser": "dev",

    // Forward GUI (rviz2, rqt, etc.)
    "runArgs": [
        "--network=host",
        "--ipc=host",
        "--privileged",
        "-e", "DISPLAY=${localEnv:DISPLAY}",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix:rw"
    ],

    // Extensions to install inside the container
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "xaver.clang-format",
                "ms-python.python",
                "charliermarsh.ruff",
                "redhat.vscode-xml",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker"
            ],
            "settings": {
                "cmake.configureOnOpen": false,
                "clangd.arguments": [
                    "--compile-commands-dir=${workspaceFolder}/build",
                    "--header-insertion=never"
                ],
                "files.associations": {
                    "*.xacro": "xml",
                    "*.urdf": "xml",
                    "*.sdf": "xml",
                    "*.launch.py": "python",
                    "*.repos": "yaml"
                }
            }
        }
    },

    // Source ROS 2 setup on terminal open
    "postStartCommand": "echo 'source /opt/ros/jazzy/setup.bash' >> ~/.bashrc",

    // Install workspace dependencies after container creation
    "postCreateCommand": "echo 'TODO: rdt local prepare'"
}
